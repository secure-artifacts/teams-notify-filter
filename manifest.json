{
  "manifest_version": 3,
  "name": "Teams 通知过滤器",
  "version": "3.0.0",
  "description": "Teams 右侧边栏管理通知：支持 teams.live.com，显示全部群组并打开聊天。",
  "permissions": ["storage", "notifications", "tabs", "scripting", "alarms"],
  "host_permissions": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams 通知过滤器"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["notification-guard.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": [
        "teams-idb.js",
        "teams-nav.js",
        "thread-utils.js",
        "teams-sidebar.js",
        "content.js"
      ],
      "css": ["teams-sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["notification-guard-page.js"],
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"]
    }
  ]
}
