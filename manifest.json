{
  "manifest_version": 3,
  "name": "Teams 通知设置",
  "version": "5.6.8",
  "description": "Teams 通知过滤 + 聊天内群组/邀请链接网页直达。",
  "permissions": ["storage"],
  "host_permissions": ["*://teams.microsoft.com/*", "*://teams.live.com/*"],
  "action": {
    "default_title": "Teams 通知设置"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://teams.microsoft.com/*", "*://teams.live.com/*"],
      "js": ["content-frame.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://teams.microsoft.com/*", "*://teams.live.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://teams.microsoft.com/*", "*://teams.live.com/*"],
      "js": ["title-utils.js", "teams-groups.js", "teams-nav.js", "teams-invite-resolver.js", "teams-link-handler.js", "teams-panel.js"],
      "css": ["teams-panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "teams-link-page.js", "teams-invite-join-page.js"],
      "matches": ["*://teams.microsoft.com/*", "*://teams.live.com/*"]
    }
  ]
}
