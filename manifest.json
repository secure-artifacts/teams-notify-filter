{
  "manifest_version": 3,
  "name": "Teams 通知过滤器",
  "version": "2.1.3",
  "description": "在 Teams 页面管理通知文件夹：拦截网页原生通知，私聊始终提醒，仅通知文件夹内群组提醒。",
  "permissions": ["storage", "notifications", "tabs", "scripting", "alarms"],
  "host_permissions": ["https://teams.microsoft.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams 通知过滤器"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*"],
      "js": ["notification-guard.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://teams.microsoft.com/*"],
      "js": ["thread-utils.js", "teams-panel.js", "content.js"],
      "css": ["teams-panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["teams-panel.css", "notification-guard-page.js"],
      "matches": ["https://teams.microsoft.com/*"]
    }
  ]
}
